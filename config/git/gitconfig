# ~/.gitconfig (symlinked from ~/dotfiles/config/git/gitconfig)

[user]
    name = TJ
    # Keep email in ~/.gitconfig.local so you don't leak it in public repos

[init]
    defaultBranch = main

[core]
    editor = nvim
    autocrlf = input
    excludesfile = ~/.config/git/gitignore_global

[pull]
    rebase = false

[fetch]
    prune = true

[push]
    default = simple
    autoSetupRemote = true

# Use delta automatically when installed.
# This won't crash git if delta isn't installed; git just falls back.
[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    navigate = true
    side-by-side = false
    line-numbers = true

[interactive]
    diffFilter = delta --color-only

[alias]
    st = status -sb
    co = checkout
    br = branch
    sw = switch
    ci = commit
    cm = commit -m
    amend = commit --amend --no-edit
    last = log -1 --stat
    lg = log --oneline --decorate --graph --all

[include]
    path = ~/.gitconfig.local
